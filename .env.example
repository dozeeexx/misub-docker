# Required on first startup. After changing the password in the UI, SQLite can
# keep the password even if ADMIN_PASSWORD is removed. If kept, this value wins.
ADMIN_PASSWORD=

# Required. Keep this stable or existing login sessions will be invalidated.
COOKIE_SECRET=

# Host address and port exposed by Docker Compose. The container always listens on 8787.
# Keep BIND_ADDRESS=127.0.0.1 when using Caddy/Nginx for public HTTPS.
BIND_ADDRESS=127.0.0.1
HOST_PORT=8787
PORT=8787

# SQLite database path inside the container.
DATABASE_PATH=/data/misub.db

# Optional comma-separated origins. Empty means the current request origin.
CORS_ORIGINS=

# Optional public URL used by callback/subscription link generation.
# MISUB_PUBLIC_URL=https://misub.example.com
# MISUB_CALLBACK_URL=https://misub.example.com

# Container-internal scheduler.
CRON_ENABLED=true
CRON_INTERVAL_SECONDS=86400
CRON_RUN_ON_START=false

# Optional diagnostics. Do not enable on public instances unless needed.
ENABLE_AUTH_DIAGNOSTICS=false
