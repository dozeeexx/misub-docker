{
  "name": "misub-docker",
  "version": "2.7.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:server": "npx wrangler pages dev public --port 8787",
    "build": "vite build",
    "preview": "vite preview",
    "start:docker": "node server/index.js",
    "sync:setup": "node scripts/setup-docker-fork-git.mjs",
    "sync:migrate": "node scripts/migrate-snapshot-to-fork.mjs",
    "sync:upstream": "node scripts/sync-upstream.mjs",
    "sync:verify": "node scripts/verify-docker-fork.mjs",
    "rules:verify": "node scripts/verify-builtin-rules.mjs",
    "sync:test": "npm run sync:verify && npm run build && npm test -- --run",
    "misub:vps": "node scripts/misub-vps.mjs",
    "misub:status": "node scripts/misub-vps.mjs status",
    "misub:health": "node scripts/misub-vps.mjs health",
    "misub:logs": "node scripts/misub-vps.mjs logs",
    "misub:backup": "node scripts/misub-vps.mjs backup",
    "misub:update": "node scripts/misub-vps.mjs update",
    "update:selfhost": "node scripts/update-selfhost.mjs",
    "update:deploy": "node scripts/update-selfhost.mjs --deploy",
    "test": "vitest --passWithNoTests",
    "test:run": "vitest run --passWithNoTests",
    "test:coverage": "vitest run --coverage --passWithNoTests"
  },
  "dependencies": {
    "better-sqlite3": "^12.5.0",
    "dompurify": "^3.2.6",
    "js-yaml": "^4.1.0",
    "pinia": "^3.0.3",
    "qrcode": "^1.5.4",
    "vue": "^3.5.18",
    "vue-router": "^4.6.4",
    "vuedraggable": "^4.1.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.18",
    "@vitejs/plugin-vue": "^6.0.1",
    "@vue/test-utils": "^2.4.6",
    "happy-dom": "^20.0.11",
    "miniflare": "^4.20250803.0",
    "playwright": "^1.60.0",
    "tailwindcss": "^4.1.12",
    "terser": "^5.48.0",
    "vite": "^7.1.2",
    "vitest": "^4.0.16",
    "wrangler": "^4.56.0"
  }
}
