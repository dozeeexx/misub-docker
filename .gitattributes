# 自动标准化换行符
* text=auto

# 确保这些文件始终使用LF换行符
*.js text eol=lf
*.vue text eol=lf
*.css text eol=lf
*.md text eol=lf
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf

# 确保这些文件保持原样
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg binary

# Docker self-hosting fork files. Run `npm run sync:setup` once so the
# keepDocker merge driver is configured in local Git config.
/server/** merge=keepDocker
/Dockerfile merge=keepDocker
/docker-compose.yml merge=keepDocker
/.dockerignore merge=keepDocker
/.env.example merge=keepDocker
/DOCKER.md merge=keepDocker
/MAINTENANCE.md merge=keepDocker
/tests/unit/docker-sqlite-runtime.test.js merge=keepDocker
/scripts/migrate-snapshot-to-fork.mjs merge=keepDocker
/scripts/setup-docker-fork-git.mjs merge=keepDocker
/scripts/sync-upstream.mjs merge=keepDocker
/scripts/update-selfhost.mjs merge=keepDocker
/scripts/verify-docker-fork.mjs merge=keepDocker
/scripts/verify-builtin-rules.mjs merge=keepDocker
/src/constants/transform-assets.js merge=keepDocker
/src/shared/acl4ssr-official-flat-presets.js merge=keepDocker
/functions/modules/subscription/transform-template-cache.js merge=keepDocker
/functions/modules/subscription/official-acl4ssr-refresh.js merge=keepDocker
/scripts/misub-vps.mjs merge=keepDocker
/deployment/caddy/** merge=keepDocker
/.gitattributes merge=keepDocker
